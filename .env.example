# ContentCraft AI — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

# Required: OpenAI API key (GPT-4 + DALL-E 3)
OPENAI_API_KEY=sk-your-openai-key-here

# Optional: YouTube Data API v3 (for live hashtag trends)
YOUTUBE_API_KEY=your-youtube-api-key-here

# Required: Flask secret key (generate with: python -c "import secrets; print(secrets.token_hex())")
SECRET_KEY=your-secure-random-secret-here

# Flask environment (development or production)
FLASK_ENV=production

# Redis URL (default works for Docker Compose)
REDIS_URL=redis://redis:6379/0
